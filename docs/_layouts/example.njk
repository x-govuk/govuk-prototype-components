{% extends "govuk/template.njk" %}
{% from "x-govuk/components/autocomplete/macro.njk" import xGovukAutocomplete %}

{% block head %}
  <script src="/assets/govuk-prototype-components.min.js" type="module"></script>
  <link rel="stylesheet" href="/assets/example.css">
{% endblock %}

{% block govukSkipLink %}{% endblock %}

{% block govukHeader %}{% endblock %}

{% block content %}
  {{ content }}
{% endblock %}

{% block bodyEnd %}
  <script src="/assets/iframeResizer.contentWindow.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      window.GOVUKPrototypeComponents.initAll()
    })
  </script>
{% endblock %}

{% block govukFooter %}{% endblock %}
